{
    "id": "catpuccin-theme",
    "name": "Catpuccin Theme",
    "description": "Fxpanel theme based on catpuccin, light/dark theme toggle, color palette, and logos",
    "version": "1.0.0",
    "author": "WEEZOOKA",
    "license": "MIT",
    "fxpanel": {
        "minVersion": "0.1.0-Beta"
    },
    "permissions": {
        "required": ["storage"],
        "optional": []
    },
    "server": {
        "entry": "server/index.js"
    },
    "panel": {
        "entry": "panel/index.js",
        "styles": "panel/index.css",
        "pages": [],
        "widgets": [
            {
                "slot": "header.dropdown",
                "title": "Theme Toggle",
                "component": "ThemeToggleDropdownItem"
            }
        ]
    },
    "nui": {
        "entry": "nui/index.js",
        "styles": "nui/index.css",
        "pages": []
    }
}
